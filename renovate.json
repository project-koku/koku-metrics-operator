{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",

  "tekton": {
    "includePaths": [".tekton/**"]
  },
  "enabledManagers": ["tekton", "dockerfile", "gomod"],
  "prConcurrentLimit": 4,
  "addLabels": ["dependencies"],
  "gomod": {
    "enabled": true,
    "packageRules": [
      {
        "matchPackageNames": ["*"],
        "matchUpdateTypes": ["digest", "patch", "minor"],
        "groupName": "all go deps (non-major)",
        "groupSlug": "go-deps-non-major"
      },
      {
        "matchPackageNames": ["*"],
        "matchUpdateTypes": ["major"],
        "groupName": "all go deps (major)",
        "groupSlug": "go-deps-major"
      }
    ]
  },
  "ignorePaths": ["vendor/**"],
  "packageRules": [
    {
        "matchDatasources": ["docker"],
        "matchPackageNames": ["registry.redhat.io/ubi9/ubi-micro"],
        "versioning": "redhat"
    }
  ]
}
